# -------------------------
# Local / secret configs
# -------------------------

.env
.env.*
!.env.example

/admin_app/.env
/admin_app/.env.*
!/admin_app/.env.example

/admin_app/config.php
/admin_app/config.local.php
/admin_app/config.prod.php
/admin_app/config.dev.php

/config.php
/config.local.php
/config.prod.php
/config.dev.php

# Keep examples
!config.example.php
!/admin_app/config.example.php


# -------------------------
# Uploads / user files
# -------------------------

/uploads/*
!/uploads/.gitkeep

/admin_app/uploads/*
!/admin_app/uploads/.gitkeep


# -------------------------
# Logs
# -------------------------

*.log
error_log
debug.log
php_errors.log

/logs/*
!/logs/.gitkeep

/admin_app/logs/*
!/admin_app/logs/.gitkeep


# -------------------------
# Cache / temp / sessions
# -------------------------

/cache/*
!/cache/.gitkeep

/tmp/*
!/tmp/.gitkeep

/temp/*
!/temp/.gitkeep

/sessions/*
!/sessions/.gitkeep

/admin_app/cache/*
!/admin_app/cache/.gitkeep

/admin_app/tmp/*
!/admin_app/tmp/.gitkeep

/admin_app/temp/*
!/admin_app/temp/.gitkeep

/admin_app/sessions/*
!/admin_app/sessions/.gitkeep


# -------------------------
# Database dumps / backups
# -------------------------

*.sql
*.sql.gz
*.dump
*.backup
*.bak


# -------------------------
# Archives
# -------------------------

*.zip
*.tar
*.tar.gz
*.rar
*.7z


# -------------------------
# Keys / certificates
# -------------------------

*.pem
*.key
*.crt
*.cert
.htpasswd
id_rsa
id_rsa.pub


# -------------------------
# OS / IDE files
# -------------------------

.DS_Store
Thumbs.db
.idea/
.vscode/


# -------------------------
# Composer dependencies
# -------------------------

/vendor/

# But keep lock file if you use Composer
!composer.lock


# -------------------------
# Node dependencies / builds
# -------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*